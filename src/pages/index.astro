---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="VexienneÂź â Modern Hair Care, Powered by FollicopeptideÂź"
  description="VexienneÂź â a modern hair care brand series built around patented FollicopeptideÂź peptide research. Discover VexienneÂź Hair Active Xâą."
  currentPath="/"
  bodyClass="bg-deep-green"
  navSticky={false}
>

  <!-- HERO. Single-viewport landing on /. Nav is in normal flow (non-sticky),
       so hero sits below it. min-h subtracts approximate nav height per breakpoint
       (logo h-X + py-Y) so nav + hero together fill exactly one viewport. -->
  <section
    id="hero"
    class="relative min-h-[calc(100svh-4.75rem)] md:min-h-[calc(100svh-6rem)] lg:min-h-[calc(100svh-7rem)] flex items-center bg-deep-green overflow-hidden"
    aria-label="Hero"
  >
    <!-- Background image -->
    <div class="absolute inset-0">
      <picture>
        <source srcset="/images/mood/hair-parting.webp" type="image/webp" />
        <img
          src="/images/mood/hair-parting.jpg"
          alt=""
          role="presentation"
          class="w-full h-full object-cover opacity-[0.18]"
        />
      </picture>
    </div>

    <!-- Crossed X â fades in bottom-right -->
    <div class="absolute bottom-0 right-0 z-[1] pointer-events-none overflow-hidden" aria-hidden="true">
      <img
        src="/images/logos/crossed-x-white.png"
        alt=""
        role="presentation"
        class="w-56 sm:w-72 md:w-96 lg:w-[32rem] opacity-0 animate-crossed-x"
      />
    </div>

    <div class="relative z-10 w-full max-w-7xl mx-auto px-5 sm:px-8 md:px-12 lg:px-20 py-16 md:py-24">
      <div class="max-w-4xl">
        <h1 class="font-display text-[2.75rem] sm:text-5xl md:text-[4rem] lg:text-[5rem] font-normal text-breathing-teal leading-[1.05] tracking-tight mb-5 md:mb-6">
          Hair thinning is not a destiny.
        </h1>
        <p class="text-xl sm:text-2xl md:text-3xl text-breathing-teal font-body max-w-2xl mb-8 md:mb-10 leading-snug">
          It can be reversed.
        </p>
        <a
          href="/hair-active-x"
          class="inline-block border border-vex-purple bg-vex-purple text-white px-8 sm:px-10 py-3.5 sm:py-4 text-xs sm:text-sm tracking-[0.14em] uppercase font-body font-medium hover:bg-vex-purple/85 hover:border-vex-purple/85 transition-colors duration-300"
        >
          Start your journey
        </a>
      </div>
    </div>
  </section>

</Layout>
